APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
RESEARCH_GATEWAY_MODE=local
RETRIEVAL_BACKEND=demo
EMBEDDING_BACKEND=hash
DOCUMENT_STRUCTURE_BACKEND=gold
EVIDENCE_GRAPH_BACKEND=gold
# Optional local-only page rendering for a rights-confirmed private PDF copy.
# The raw PDF is never returned. Keep disabled in shared or hosted environments.
PRIVATE_PDF_PREVIEW_ENABLED=false
PRIVATE_PDF_PREVIEW_ROOT=
ASSISTANT_BACKEND=offline
# memory keeps the fully offline demo dependency-free; mysql survives API restarts.
ASSISTANT_SESSION_BACKEND=memory
PROJECT_CLAIM_BACKEND=memory
EXPERIMENT_RUN_BACKEND=memory
CORS_ORIGINS=http://localhost:5173

# Optional infrastructure
MYSQL_PORT=3306
MYSQL_URL=mysql+pymysql://kd_agent:kd_agent_local@127.0.0.1:3306/kd_agent
MILVUS_URI=http://127.0.0.1:19530
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=kd_agent_graph_local

# Never commit real secrets
ASTRON_AGENT_API_KEY=
ASTRON_AGENT_API_SECRET=
ASTRON_AGENT_FLOW_ID=
ASTRON_AGENT_API_URL=https://xingchen-api.xf-yun.com/workflow/v1/chat/completions
ASTRON_AGENT_MODEL_LABEL=configured-in-workflow
ASSISTANT_MODEL_TIMEOUT_SECONDS=30
